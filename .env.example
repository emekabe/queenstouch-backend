# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/queenstouch

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-256-bit-secret
JWT_ACCESS_EXPIRY_MS=900000      # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000  # 7 days

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.0-flash

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Sign up and get your API key at: https://resend.com
# IMPORTANT: RESEND_FROM_ADDRESS must be a verified domain address in Resend (not a Gmail)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_ADDRESS=noreply@yourdomain.com
RESEND_FROM_NAME=Queenstouch

# ─── Google Cloud Storage ────────────────────────────────────────────────────
GOOGLE_CLOUD_STORAGE_PROJECT_ID=your-google-cloud-project-id
GOOGLE_CLOUD_STORAGE_BUCKET=queenstouch-premium-uploads
GOOGLE_CLOUD_STORAGE_CREDENTIALS_BASE64=your_base64_encoded_service_account_json

# ─── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5MB
MAX_REQUEST_SIZE=5MB

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:3000
ADMIN_REGISTER_SECRET=default_dev_admin_secret_12345
