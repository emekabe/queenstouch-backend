# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/queenstouch

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-256-bit-secret
JWT_ACCESS_EXPIRY_MS=900000      # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000  # 7 days

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.0-flash

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=your-smtp-password

# ─── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:3000
ADMIN_REGISTER_SECRET=default_dev_admin_secret_12345
